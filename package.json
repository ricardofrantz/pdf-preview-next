{
  "name": "pdf-preview-next",
  "displayName": "PDF Preview Next",
  "description": "A lightweight PDF preview extension for VS Code with modern PDF.js, reliable refresh, and secure webviews.",
  "version": "1.4.2",
  "publisher": "ricardofrantz",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=22"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "pdf",
    "viewer",
    "preview",
    "pdfjs",
    "latex",
    "typst"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ricardofrantz/pdf-preview-next.git"
  },
  "bugs": {
    "url": "https://github.com/ricardofrantz/pdf-preview-next/issues"
  },
  "activationEvents": [
    "onCustomEditor:pdf-preview-next.preview",
    "onCommand:pdf-preview.openPreview",
    "onCommand:pdf-preview.openSource",
    "onCommand:pdf-preview.refreshPreview",
    "onCommand:pdf-preview.print"
  ],
  "main": "./out/src/extension",
  "contributes": {
    "capabilities": {
      "untrustedWorkspaces": {
        "supported": true
      }
    },
    "customEditors": [
      {
        "viewType": "pdf-preview-next.preview",
        "displayName": "PDF Preview Next",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "pdf-preview.openPreview",
        "title": "PDF Preview Next: Open Preview"
      },
      {
        "command": "pdf-preview.openSource",
        "title": "PDF Preview Next: Open Source"
      },
      {
        "command": "pdf-preview.refreshPreview",
        "title": "PDF Preview Next: Refresh Preview"
      },
      {
        "command": "pdf-preview.print",
        "title": "PDF Preview Next: Print"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "PDF Preview",
      "properties": {
        "pdf-preview.default.cursor": {
          "markdownDescription": "The default cursor tool for preview.",
          "type": "string",
          "default": "select",
          "enum": [
            "select",
            "hand"
          ]
        },
        "pdf-preview.default.scale": {
          "markdownDescription": "The default zoom level for preview. Allowed values are `auto`, `page-actual`, `page-fit`, `page-width`, and 1-based scale values. (`1.0` means 100%)",
          "type": "string",
          "default": "auto",
          "pattern": "^(\\d+(?:\\.\\d+)?|auto|page-actual|page-fit|page-width)$"
        },
        "pdf-preview.default.sidebar": {
          "markdownDescription": "Open the document outline sidebar by default when the PDF has an outline.",
          "type": "boolean",
          "default": false
        },
        "pdf-preview.default.scrollMode": {
          "markdownDescription": "The default scroll mode for preview.",
          "type": "string",
          "default": "vertical",
          "enum": [
            "vertical",
            "horizontal",
            "wrapped"
          ]
        },
        "pdf-preview.default.spreadMode": {
          "markdownDescription": "The default spread mode for preview.",
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "odd",
            "even"
          ]
        },
        "pdf-preview.reload.closeOnDelete": {
          "markdownDescription": "Close the preview when the opened PDF is deleted. Disable this for TeX-style build workflows that temporarily delete and recreate the PDF.",
          "type": "boolean",
          "default": false
        },
        "pdf-preview.reload.debounceMs": {
          "markdownDescription": "Milliseconds to wait after PDF file change notifications before refreshing the preview. Increase this if your build tool writes PDFs in multiple bursts.",
          "type": "number",
          "default": 800,
          "minimum": 0,
          "maximum": 10000
        },
        "pdf-preview.appearance.theme": {
          "markdownDescription": "Preview appearance. `auto` follows VS Code colors, `dark` darkens chrome, and `inverted` also inverts rendered PDF pages.",
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark",
            "inverted"
          ]
        },
        "pdf-preview.appearance.pageGap": {
          "markdownDescription": "Spacing between rendered PDF pages.",
          "type": "string",
          "default": "normal",
          "enum": [
            "compact",
            "normal",
            "wide"
          ]
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "watch": "tsc -w -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/src/test/runTest.js",
    "lint": "eslint ./src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "update:pdfjs": "node ./tools/update_pdfjs.mjs",
    "package": "vsce package",
    "package:scan": "node ./tools/scan_vsix.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "extensionKind": [
    "ui"
  ]
}
